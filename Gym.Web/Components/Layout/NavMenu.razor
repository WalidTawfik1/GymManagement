<div class="p-6 text-center border-b border-white/10 mb-4 flex flex-col items-center">
    <img src="images/GymLogo.jpg" alt="Gym Logo" class="w-24 h-24 object-cover rounded-full shadow-lg border-2 border-gym-accent mb-2" />
    <h3 class="text-white font-bold mt-2 text-lg">Mambela Gym</h3>
</div>

<nav class="flex flex-col gap-2 px-4 pb-6">
    <div class="nav-item">
        <NavLink class="flex items-center gap-3 px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-all" href="" Match="NavLinkMatch.All">
            <i class="bi bi-house-door-fill text-xl text-gym-accent"></i> 
            <span class="font-semibold text-[15px]">الرئيسية</span>
        </NavLink>
    </div>
    
    <div class="nav-item">
        <NavLink class="flex items-center gap-3 px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-all" href="trainees">
            <i class="bi bi-people-fill text-xl text-gym-accent"></i>
            <span class="font-semibold text-[15px]">إدارة المتدربين</span>
        </NavLink>
    </div>

    <div class="nav-item">
        <NavLink class="flex items-center gap-3 px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-all" href="memberships">
            <i class="bi bi-card-checklist text-xl text-gym-accent"></i>
            <span class="font-semibold text-[15px]">العضويات والاشتراكات</span>
        </NavLink>
    </div>

    <div class="nav-item">
        <NavLink class="flex items-center gap-3 px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-all" href="visits">
            <i class="bi bi-calendar-check-fill text-xl text-gym-accent"></i>
            <span class="font-semibold text-[15px]">تسجيل الزيارات</span>
        </NavLink>
    </div>

    <div class="nav-item">
        <NavLink class="flex items-center gap-3 px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-all" href="services">
            <i class="bi bi-cart-fill text-xl text-gym-accent"></i>
            <span class="font-semibold text-[15px]">الخدمات الإضافية</span>
        </NavLink>
    </div>

    <div class="nav-item">
        <NavLink class="flex items-center gap-3 px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-all" href="accounting">
            <i class="bi bi-wallet-fill text-xl text-gym-accent"></i>
            <span class="font-semibold text-[15px]">الإيرادات والمصروفات</span>
        </NavLink>
    </div>

    <div class="nav-item">
        <NavLink class="flex items-center gap-3 px-4 py-3 text-white/80 hover:text-white hover:bg-white/10 rounded-xl transition-all" href="security-settings">
            <i class="bi bi-shield-lock-fill text-xl text-gym-accent"></i>
            <span class="font-semibold text-[15px]">إعدادات الحماية</span>
        </NavLink>
    </div>

    <div class="nav-item mt-4">
        <form action="/api/auth/logout" method="post">
            <AntiforgeryToken />
            <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 text-red-400 hover:text-red-300 hover:bg-white/10 rounded-xl transition-all">
                <i class="bi bi-box-arrow-right text-xl"></i>
                <span class="font-semibold text-[15px]">تسجيل الخروج</span>
            </button>
        </form>
    </div>
</nav>

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
}
