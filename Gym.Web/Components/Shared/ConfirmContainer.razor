@using Gym.Web.Services
@inject ConfirmService ConfirmService
@implements IDisposable
@rendermode InteractiveServer

@if (isVisible)
{
    <div class="fixed inset-0 bg-black/60 z-[110] flex items-center justify-center p-4 backdrop-blur-sm transition-opacity" dir="rtl">
        <div class="bg-white rounded-2xl shadow-2xl w-[95%] sm:w-full max-w-sm overflow-hidden flex flex-col transform transition-all scale-100 opacity-100 animate-fade-in-up">
            <div class="p-6 text-center">
                <div class="w-16 h-16 bg-red-100 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h5 class="font-bold text-xl text-gray-800 mb-2">@title</h5>
                <p class="text-gray-600 mb-6">@message</p>
                <div class="flex gap-3 justify-center">
                    <button class="flex-1 px-5 py-2.5 rounded-xl font-bold text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors" @onclick="() => Respond(false)">إلغاء</button>
                    <button class="flex-1 px-5 py-2.5 rounded-xl font-bold text-white bg-red-500 hover:bg-red-600 transition-colors" @onclick="() => Respond(true)">تأكيد</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isVisible = false;
    private string title = "";
    private string message = "";
    private TaskCompletionSource<bool>? _tcs;

    protected override void OnInitialized()
    {
        ConfirmService.OnShow = ShowConfirmAsync;
    }

    private Task<bool> ShowConfirmAsync(string msg, string t)
    {
        title = t;
        message = msg;
        isVisible = true;
        _tcs = new TaskCompletionSource<bool>();
        InvokeAsync(StateHasChanged);
        return _tcs.Task;
    }

    private void Respond(bool result)
    {
        isVisible = false;
        _tcs?.SetResult(result);
        StateHasChanged();
    }

    public void Dispose()
    {
        if (ConfirmService.OnShow == ShowConfirmAsync)
        {
            ConfirmService.OnShow = null;
        }
    }
}
