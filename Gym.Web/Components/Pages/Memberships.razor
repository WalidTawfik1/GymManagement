@page "/memberships"
@using Gym.Core.Models
@using Gym.Core.DTO
@using Gym.Core.Interfaces
@using Gym.Core.Helpers
@inject IUnitofWork UnitOfWork
@inject IJSRuntime JS
@inject Gym.Core.Interfaces.Services.IReportService ReportService
@rendermode InteractiveServer

<PageTitle>إدارة العضويات</PageTitle>

<div class="container mx-auto" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div>
            <h2 class="font-bold text-2xl text-gym-primary mb-1">💳 إدارة العضويات</h2>
            <p class="text-gray-500 text-sm">إدارة الاشتراكات وخطط العضوية</p>
        </div>
        <div class="flex gap-2">
            <button class="btn-outline flex items-center gap-2" @onclick="ExportReport">
                <i class="bi bi-file-earmark-excel"></i> تصدير إكسيل
            </button>
            <button class="btn-primary flex items-center gap-2" @onclick="ShowAddModal">
                <i class="bi bi-plus-lg"></i> إضافة عضوية
            </button>
        </div>
    </div>

    <!-- Filters & Search -->
    <div class="flex flex-wrap gap-4 mb-6">
        <div class="w-full md:w-48">
            <select class="input-modern" @bind="selectedMonth" @bind:after="LoadData">
                @for(int i=1; i<=12; i++)
                {
                    <option value="@i">شهر @i</option>
                }
            </select>
        </div>
        <div class="w-full md:w-48">
            <select class="input-modern" @bind="selectedYear" @bind:after="LoadData">
                @for(int y=2020; y<=2050; y++)
                {
                    <option value="@y">سنة @y</option>
                }
            </select>
        </div>
        <div class="w-full md:flex-1 min-w-[200px]">
            <div class="relative">
                <input type="text" class="input-modern w-full pr-10" placeholder="ابحث باسم المتدرب..." @bind="SearchQuery" @bind:event="oninput" @onkeyup="SearchMemberships" />
                <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                    <i class="bi bi-search text-gray-400"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="card-modern p-4 text-center">
            <p class="text-gray-500 text-sm mb-1">إجمالي الاشتراكات</p>
            <h3 class="text-2xl font-bold text-gym-primary">@memberships.Count</h3>
        </div>
        <div class="card-modern p-4 text-center">
            <p class="text-gray-500 text-sm mb-1">الاشتراكات النشطة</p>
            <h3 class="text-2xl font-bold text-gym-success">@memberships.Count(m => m.IsActive)</h3>
        </div>
        <div class="card-modern p-4 text-center">
            <p class="text-gray-500 text-sm mb-1">إجمالي الإيرادات</p>
            <h3 class="text-2xl font-bold text-gym-warning">@memberships.Sum(m => m.Price).ToString("N0") ج.م</h3>
        </div>
    </div>

    <!-- Table -->
    <div class="card-modern overflow-hidden">
        <div class="overflow-x-auto">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th class="pr-6">الرقم</th>
                        <th>اسم المتدرب</th>
                        <th>نوع العضوية</th>
                        <th>السعر</th>
                        <th>البداية</th>
                        <th>النهاية</th>
                        <th>الحصص المتبقية</th>
                        <th>الحالة</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="9" class="text-center py-8">
                                <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-gym-primary"></div>
                            </td>
                        </tr>
                    }
                    else if (!filteredMemberships.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-8 text-gray-500">لا يوجد عضويات لهذا الشهر.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var mem in filteredMemberships)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="pr-6 text-gray-500">#@mem.Id</td>
                                <td class="font-bold text-gray-800">@mem.TraineeName</td>
                                <td class="text-gray-700">@mem.MembershipType</td>
                                <td class="text-gym-success font-bold">@mem.Price.ToString("N0") ج.م</td>
                                <td class="text-gray-600">@mem.StartDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-gray-600">@mem.EndDate.ToString("yyyy-MM-dd")</td>
                                <td><span class="badge-modern bg-gray-200 text-gray-700">@(mem.RemainingSessions?.ToString() ?? "مفتوح")</span></td>
                                <td>
                                    @if (mem.IsActive)
                                    {
                                        <span class="badge-modern bg-gym-success text-white">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern bg-gym-danger text-white">منتهي</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="flex justify-center gap-2">
                                        <button class="btn-outline text-sm" @onclick="() => EditMembership(mem)">تعديل</button>
                                        <button class="btn-danger text-sm" @onclick="() => DeleteMembership(mem)">حذف</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal for Add/Edit -->
@if (isModalOpen)
{
    <div class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden flex flex-col" dir="rtl">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                <h5 class="font-bold text-lg text-gym-primary">@(isEditMode ? "تعديل العضوية" : "إضافة عضوية جديدة")</h5>
                <button type="button" class="text-gray-400 hover:text-gray-700 text-2xl leading-none" @onclick="CloseModal">&times;</button>
            </div>
            <div class="p-6">
                
                @if (!isEditMode)
                {
                    <div class="mb-4">
                        <label class="block text-sm font-bold text-gray-700 mb-2">اختر المتدرب <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <input type="text" class="input-modern w-full" placeholder="-- ابحث بالاسم أو الرقم --" @bind="SearchTraineeText" @bind:event="oninput" @onclick="() => showTraineeDropdown = true" />
                            @if (showTraineeDropdown)
                            {
                                <div class="fixed inset-0 z-40" @onclick="() => showTraineeDropdown = false"></div>
                                <div class="absolute z-50 w-full mt-1 bg-white border border-gray-200 rounded-xl shadow-xl max-h-48 overflow-y-auto" dir="rtl">
                                    @if (!traineesList.Any())
                                    {
                                        <div class="px-4 py-3 text-gray-500 text-sm">لا يوجد متدربين.</div>
                                    }
                                    else
                                    {
                                        @foreach(var trainee in traineesList.Where(t => string.IsNullOrWhiteSpace(SearchTraineeText) || t.FullName.Contains(SearchTraineeText) || t.Id.ToString() == SearchTraineeText || t.PhoneNumber.Contains(SearchTraineeText)))
                                        {
                                            <div class="px-4 py-2 hover:bg-gym-primary hover:text-white cursor-pointer transition-colors border-b border-gray-50 last:border-0" 
                                                 @onclick="() => SelectTrainee(trainee.Id, trainee.FullName)">
                                                #@trainee.Id - @trainee.FullName - @trainee.PhoneNumber
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="mb-4">
                    <label class="block text-sm font-bold text-gray-700 mb-2">نوع العضوية <span class="text-red-500">*</span></label>
                    <select class="input-modern" @bind="currentMembershipType">
                        <option value="شهر">اشتراك شهري (مفتوح)</option>
                        <option value="12 حصة">اشتراك 12 حصة</option>
                        <option value="8 حصص">اشتراك 8 حصص</option>
                        <option value="حصة واحدة">حصة واحدة (يومي)</option>
                        <option value="3 شهور">اشتراك 3 شهور</option>
                        <option value="VIP">VIP</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-bold text-gray-700 mb-2">السعر <span class="text-red-500">*</span></label>
                    <input type="number" class="input-modern" @bind="price" placeholder="0" />
                </div>
                
                @if (isEditMode)
                {
                    <div class="flex gap-4 mb-4">
                        <div class="w-1/2">
                            <label class="block text-sm font-bold text-gray-700 mb-2">تاريخ البداية</label>
                            <input type="date" class="input-modern" @bind="startDate" />
                        </div>
                        <div class="w-1/2">
                            <label class="block text-sm font-bold text-gray-700 mb-2">تاريخ النهاية</label>
                            <input type="date" class="input-modern" @bind="endDate" />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="block text-sm font-bold text-gray-700 mb-2">الحصص المتبقية (اختياري)</label>
                        <input type="number" class="input-modern" @bind="remainingSessions" />
                    </div>
                    <div class="flex items-center mb-4 mt-2">
                        <input type="checkbox" id="isActiveSwitch" class="w-5 h-5 text-gym-primary rounded border-gray-300 focus:ring-gym-primary ml-2" @bind="isActive">
                        <label class="font-bold text-sm text-gray-700 mr-2" for="isActiveSwitch">الاشتراك نشط</label>
                    </div>
                }

            </div>
            <div class="px-6 py-4 border-t border-gray-100 bg-gray-50 flex justify-end gap-3">
                <button type="button" class="px-5 py-2 rounded-xl font-bold text-gray-600 hover:bg-gray-200 transition-colors" @onclick="CloseModal">إلغاء</button>
                <button type="button" class="btn-primary px-8" @onclick="SaveMembership">حفظ</button>
            </div>
        </div>
    </div>
}

@code {
    private List<MembershipDTO> memberships = new();
    private List<MembershipDTO> filteredMemberships = new();
    private List<Trainee> traineesList = new();
    private bool isLoading = true;
    private string SearchQuery = "";
    
    private int selectedMonth = DateTime.Now.Month;
    private int selectedYear = DateTime.Now.Year;
    
    // Modal State
    private bool isModalOpen = false;
    private bool isEditMode = false;
    
    private int selectedTraineeId = 0;
    private string SearchTraineeText = "";
    private bool showTraineeDropdown = false;
    private int currentMembershipId = 0;
    private string currentMembershipType = "شهر";
    private DateTime startDate = DateTime.Today;
    private DateTime endDate = DateTime.Today.AddMonths(1);
    private decimal price = 0;
    private int? remainingSessions = null;
    private bool isActive = true;
    
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        selectedMonth = AccountingDateHelper.GetCurrentAccountingMonth();
        selectedYear = AccountingDateHelper.GetCurrentAccountingYear();
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;
        
        // Pass month/year to get filtered results
        memberships = (await UnitOfWork.MembershipRepository.GetAllMembershipsAsync(selectedMonth, selectedYear)).ToList();
        traineesList = (await UnitOfWork.TraineeRepository.GetAllTraineesAsync()).ToList();
        
        filteredMemberships = memberships.OrderByDescending(m => m.Id).ToList();
        isLoading = false;
    }

    private void SearchMemberships()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            filteredMemberships = memberships.OrderByDescending(m => m.Id).ToList();
        }
        else
        {
            filteredMemberships = memberships
                .Where(m => m.TraineeName != null && m.TraineeName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
                .OrderByDescending(m => m.Id)
                .ToList();
        }
    }

    private void ShowAddModal()
    {
        isEditMode = false;
        selectedTraineeId = 0;
        SearchTraineeText = "";
        showTraineeDropdown = false;
        currentMembershipId = 0;
        currentMembershipType = "شهر";
        price = 0;
        remainingSessions = null;
        isActive = true;
        errorMessage = null;
        isModalOpen = true;
    }

    private void EditMembership(MembershipDTO mem)
    {
        isEditMode = true;
        currentMembershipId = mem.Id;
        selectedTraineeId = mem.TraineeId;
        SearchTraineeText = $"{mem.TraineeId} - {mem.TraineeName}";
        showTraineeDropdown = false;
        currentMembershipType = mem.MembershipType;
        startDate = mem.StartDate.ToDateTime(TimeOnly.MinValue);
        endDate = mem.EndDate.ToDateTime(TimeOnly.MinValue);
        price = mem.Price;
        remainingSessions = mem.RemainingSessions;
        isActive = mem.IsActive;
        errorMessage = null;
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        errorMessage = null;
    }

    private void SelectTrainee(int id, string name)
    {
        selectedTraineeId = id;
        SearchTraineeText = $"{id} - {name}";
        showTraineeDropdown = false;
    }

    private async Task SaveMembership()
    {
        errorMessage = null;
        
        if (!isEditMode)
        {
            if (selectedTraineeId == 0)
            {
                await JS.InvokeVoidAsync("alert", "يرجى اختيار المتدرب من القائمة المنسدلة.");
                return;
            }
        }
        
        if (price <= 0)
        {
            await JS.InvokeVoidAsync("alert", "يرجى إدخال سعر صحيح.");
            return;
        }

        if (isEditMode)
        {
            var updateDto = new MembershipDTO
            {
                Id = currentMembershipId,
                TraineeId = selectedTraineeId,
                TraineeName = "",
                MembershipType = currentMembershipType,
                StartDate = DateOnly.FromDateTime(startDate),
                EndDate = DateOnly.FromDateTime(endDate),
                Price = price,
                RemainingSessions = remainingSessions,
                IsActive = isActive
            };
            await UnitOfWork.MembershipRepository.UpdateMembership(updateDto);
        }
        else
        {
            var addDto = new AddMembershipDTO
            {
                TraineeId = selectedTraineeId,
                MembershipType = currentMembershipType,
                Price = price
            };
            var success = await UnitOfWork.MembershipRepository.AddMembership(addDto);
            if (!success)
            {
                await JS.InvokeVoidAsync("alert", "لم يتم إضافة الاشتراك. تأكد أن المتدرب لا يملك اشتراكاً نشطاً بالفعل.");
                return;
            }
        }

        isModalOpen = false;
        await LoadData();
    }
    
    private async Task ExportReport()
    {
        try
        {
            isLoading = true;
            var filePath = await ReportService.ExportMembershipsReportAsync(selectedMonth, selectedYear);
            if (System.IO.File.Exists(filePath))
            {
                var bytes = await System.IO.File.ReadAllBytesAsync(filePath);
                var base64 = Convert.ToBase64String(bytes);
                var fileName = Path.GetFileName(filePath);
                await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, base64);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"خطأ في التصدير: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteMembership(MembershipDTO mem)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"هل أنت متأكد من حذف عضوية {mem.TraineeName}؟");
        if (confirmed)
        {
            var membership = await UnitOfWork.MembershipRepository.GetByIdAsync(mem.Id);
            if(membership != null)
            {
                membership.IsDeleted = true;
                await UnitOfWork.MembershipRepository.UpdateAsync(membership);
                await LoadData();
            }
        }
    }
}
