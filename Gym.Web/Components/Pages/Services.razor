@page "/services"
@using Gym.Core.Models
@using Gym.Core.DTO
@using Gym.Core.Interfaces
@using Gym.Core.Helpers
@inject IUnitofWork UnitOfWork
@inject IJSRuntime JS
@inject ToastService ToastService
@inject ConfirmService ConfirmService
@inject Gym.Core.Interfaces.Services.IReportService ReportService
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>الخدمات الإضافية</PageTitle>

<div class="container mx-auto" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div>
            <h2 class="font-bold text-2xl text-gym-primary mb-1">🛒 الخدمات الإضافية</h2>
            <p class="text-gray-500 text-sm">إدارة الخدمات الإضافية مثل المشاية، الميزان، inBody وغيرها</p>
        </div>
        <div class="flex flex-wrap sm:flex-nowrap gap-2 w-full md:w-auto">
            <button class="btn-outline flex-1 justify-center flex items-center gap-2 whitespace-nowrap" @onclick="ExportReport">
                <i class="bi bi-file-earmark-excel"></i> تصدير إكسيل
            </button>
            <button class="btn-primary flex-1 justify-center flex items-center gap-2 whitespace-nowrap" @onclick="ShowAddModal">
                <i class="bi bi-plus-lg"></i> تقديم خدمة
            </button>
        </div>
    </div>

    <!-- Filters & Search -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="w-full">
            <select class="input-modern w-full" @bind="selectedMonth" @bind:after="LoadData">
                @for (int i=1; i<=12; i++)
                {
                    <option value="@i">شهر @i</option>
                }
            </select>
        </div>
        <div class="w-full">
            <select class="input-modern w-full" @bind="selectedYear" @bind:after="LoadData">
                @for (int y=2020; y<=2050; y++)
                {
                    <option value="@y">سنة @y</option>
                }
            </select>
        </div>
        <div class="w-full sm:col-span-2 lg:col-span-1">
            <input type="text" class="input-modern w-full" placeholder="ابحث باسم المتدرب أو الخدمة..." @oninput="OnSearchInput" />
        </div>
        <div class="w-full">
            <select class="input-modern w-full" @bind="PageSize" @bind:after="() => SearchServices(1)">
            <option value="10">10 لكل صفحة</option>
            <option value="25">25 لكل صفحة</option>
            <option value="50">50 لكل صفحة</option>
            <option value="100">100 لكل صفحة</option>
        </select>
    </div>
</div>

<!-- Table -->
<div class="card-modern overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table-modern">
            <thead>
                <tr>
                    <th class="pr-6">رقم العملية</th>
                    <th>اسم المتدرب</th>
                    <th>الخدمة</th>
                    <th>تاريخ الطلب</th>
                    <th>السعر</th>
                    <th class="text-center">الإجراءات</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @if (isLoading)
                {
                    <tr>
                        <td colspan="6" class="text-center py-8">
                            <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-gym-primary"></div>
                        </td>
                    </tr>
                }
                else if (!filteredServices.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-8 text-gray-500">لا يوجد خدمات مسجلة لهذا الشهر.</td>
                    </tr>
                }
                else
                {
                    @foreach (var srv in filteredServices)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="pr-6 text-gray-500">#@srv.Id</td>
                            <td class="font-bold text-gray-800">@srv.TraineeName</td>
                            <td><span class="badge-modern bg-gray-200 text-gray-700">@srv.ServiceType</span></td>
                            <td class="text-gray-600">@srv.TakenAt.ToString("yyyy-MM-dd hh:mm tt")</td>
                            <td class="text-gym-success font-bold">@srv.Price ج.م</td>
                            <td class="text-center">
                                <div class="flex justify-center gap-2">
                                    <button class="btn-outline text-sm" @onclick="() => EditService(srv)">تعديل</button>
                                    <button class="btn-danger text-sm" @onclick="() => DeleteService(srv.Id)">حذف</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    @if (pagedServices != null && pagedServices.TotalPages > 1)
    {
        <div class="px-4 py-3 sm:px-6 sm:py-4 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-4 bg-gray-50">
            <div class="text-sm text-gray-600 w-full sm:w-auto text-center sm:text-right">
                إجمالي نتائج البحث: <span class="font-bold">@pagedServices.TotalCount</span>
            </div>
            <div class="flex gap-2 w-full sm:w-auto justify-center">
                <button class="btn-outline px-3 py-1 text-sm disabled:opacity-50"
                disabled="@(!pagedServices.HasPreviousPage)"
                @onclick="() => SearchServices(CurrentPage - 1)">
                السابق
            </button>

            <span class="px-4 py-1 text-sm font-bold text-gray-700 bg-white border border-gray-200 rounded-lg">
                صفحة @pagedServices.PageNumber من @pagedServices.TotalPages
            </span>

            <button class="btn-outline px-3 py-1 text-sm disabled:opacity-50"
            disabled="@(!pagedServices.HasNextPage)"
            @onclick="() => SearchServices(CurrentPage + 1)">
            التالي
        </button>
    </div>
</div>
}
</div>
</div>

<!-- Modal for Add/Edit -->
@if (isModalOpen)
{
    <div class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-2xl w-[95%] sm:w-full max-w-lg flex flex-col" dir="rtl">
            <div class="px-4 py-3 sm:px-6 sm:py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50 rounded-t-2xl">
                <h5 class="font-bold text-lg text-gym-primary">@(isEditMode ? "تعديل الخدمة" : "تقديم خدمة جديدة")</h5>
                <button type="button" class="text-gray-400 hover:text-gray-700 text-2xl leading-none" @onclick="CloseModal">&times;</button>
            </div>
            <div class="p-4 sm:p-6 overflow-visible min-h-[350px]">

                @if (!isEditMode)
                {
                    <div class="mb-4">
                        <label class="block text-sm font-bold text-gray-700 mb-2">اختر المتدرب <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <input type="text" class="input-modern w-full" placeholder="-- ابحث بالاسم أو الرقم --" value="@SearchTraineeText" @oninput="OnTraineeSearchInput"/>
                            @if (showTraineeDropdown)
                            {
                                <div class="fixed inset-0 z-40" @onclick="() => showTraineeDropdown = false"></div>
                                <div class="absolute z-50 w-full mt-1 bg-white border border-gray-200 rounded-xl shadow-xl max-h-48 overflow-y-auto" dir="rtl">
                                    @if (!traineesList.Any())
                                    {
                                        <div class="px-4 py-3 text-gray-500 text-sm">لا يوجد متدربين.</div>
                                    }
                                    else
                                    {
                                        <div class="px-4 py-2 hover:bg-gym-primary hover:text-white cursor-pointer transition-colors border-b border-gray-50 last:border-0"
                                        @onclick='() => SelectTrainee(0, "-- بدون متدرب --")'>
                                        -- بدون متدرب --
                                    </div>
                                    @foreach (var trainee in traineesList.Where(t => string.IsNullOrWhiteSpace(SearchTraineeText) || t.FullName.Contains(SearchTraineeText) || t.Id.ToString() == SearchTraineeText || t.PhoneNumber.Contains(SearchTraineeText)))
                                    {
                                        <div class="px-4 py-2 hover:bg-gym-primary hover:text-white cursor-pointer transition-colors border-b border-gray-50 last:border-0"
                                        @onclick="() => SelectTrainee(trainee.Id, trainee.FullName)">
                                        #@trainee.Id - @trainee.FullName - @trainee.PhoneNumber
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
                <p class="text-xs text-gray-500 mt-1">الخدمات يمكن تقديمها بدون تحديد متدرب (اختر بدون متدرب).</p>
            </div>
        }

        <div class="mb-4">
            <label class="block text-sm font-bold text-gray-700 mb-2">نوع الخدمة <span class="text-red-500">*</span></label>
            <select class="input-modern" @bind="serviceName">
                <option value="مكملات غذائية (منتجات)">مكملات غذائية (منتجات)</option>
                <option value="استخدام المشاية (يومي)">استخدام المشاية (يومي)</option>
                <option value="إن بودي (InBody)">إن بودي (InBody)</option>
                <option value="أخرى">أخرى</option>
            </select>
        </div>

        <div class="mb-4">
            <label class="block text-sm font-bold text-gray-700 mb-2">السعر <span class="text-red-500">*</span></label>
            <input type="number" class="input-modern" @bind="price" />
        </div>

    </div>
    <div class="px-4 py-3 sm:px-6 sm:py-4 border-t border-gray-100 bg-gray-50 flex justify-end gap-3 rounded-b-2xl">
        <button type="button" class="flex-1 sm:flex-none px-5 py-2 rounded-xl font-bold text-gray-600 hover:bg-gray-200 transition-colors" @onclick="CloseModal">إلغاء</button>
        <button type="button" class="flex-1 sm:flex-none btn-primary px-8 disabled:opacity-50" @onclick="SaveService" disabled="@isSaving">
            @(isSaving ? "جاري الحفظ..." : "حفظ")
        </button>
    </div>
</div>
</div>
}

@code {
    private PagedResult<AdditionalServiceDTO> pagedServices = new();
    private List<AdditionalServiceDTO> filteredServices = new();
    private List<Trainee> traineesList = new();

    private bool isLoading = true;
    private string SearchQuery = "";
    private int CurrentPage = 1;
    private int PageSize = 10;

    private int selectedMonth = DateTime.Now.Month;
    private int selectedYear = DateTime.Now.Year;

    // Modal State
    private bool isModalOpen = false;
    private bool isEditMode = false;

    private int currentServiceId = 0;
    private int selectedTraineeId = 0;
    private string SearchTraineeText = "";
    private bool showTraineeDropdown = false;
    private string serviceName = "إن بودي (InBody)";
    private decimal price = 0;
    private bool isSaving = false;

    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        _debounceTimer = new System.Timers.Timer(500);
        _debounceTimer.Elapsed += OnTimerElapsed;
        _debounceTimer.AutoReset = false;

        selectedMonth = AccountingDateHelper.GetCurrentAccountingMonth();
        selectedYear = AccountingDateHelper.GetCurrentAccountingYear();

        await LoadData();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchQuery = e.Value?.ToString() ?? "";
        _debounceTimer?.Stop();
        _debounceTimer?.Start();
    }

    private System.Timers.Timer? _traineeSearchTimer;

    private void OnTraineeSearchInput(ChangeEventArgs e)
    {
        SearchTraineeText = e.Value?.ToString() ?? "";
        showTraineeDropdown = true;

        if (_traineeSearchTimer == null)
        {
            _traineeSearchTimer = new System.Timers.Timer(400);
            _traineeSearchTimer.AutoReset = false;
        }

        _traineeSearchTimer.Stop();
        _traineeSearchTimer.Start();
    }

    private async void OnTimerElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        await InvokeAsync(async () => await SearchServices(1));
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }

    private async Task LoadData()
    {
        isLoading = true;
        traineesList = (await UnitOfWork.TraineeRepository.GetAllTraineesAsync()).ToList();
        await SearchServices(1);
    }

    private async Task SearchServices(int page = 1)
    {
        isLoading = true;
        CurrentPage = page;

        pagedServices = await UnitOfWork.AdditionalServiceRepository.GetAdditionalServicesPagedAsync(
            CurrentPage, PageSize, selectedMonth, selectedYear, SearchQuery
        );

        filteredServices = pagedServices.Items.ToList();

        isLoading = false;
        StateHasChanged();
    }

    private void ShowAddModal()
    {
        isEditMode = false;
        selectedTraineeId = 0;
        SearchTraineeText = "";
        showTraineeDropdown = false;
        serviceName = "مكملات غذائية (منتجات)";
        price = 0;
        isModalOpen = true;
    }

    private void EditService(AdditionalServiceDTO srv)
    {
        isEditMode = true;
        currentServiceId = srv.Id;
        selectedTraineeId = srv.TraineeId;
        SearchTraineeText = srv.TraineeId > 0 ? $"{srv.TraineeId} - {srv.TraineeName}" : "-- بدون متدرب --";
        showTraineeDropdown = false;
        serviceName = srv.ServiceType;
        price = srv.Price;
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private void SelectTrainee(int id, string name)
    {
        selectedTraineeId = id;
        SearchTraineeText = id == 0 ? name : $"{id} - {name}";
        showTraineeDropdown = false;
    }

    private async Task SaveService()
    {
        if (isSaving) return;
        isSaving = true;
        try
        {
            if (isEditMode)
            {
                var updateDto = new AdditionalServiceDTO
                {
                    Id = currentServiceId,
                    TraineeId = selectedTraineeId,
                    TraineeName = "",
                    ServiceType = serviceName,
                    Price = price
                };
                await UnitOfWork.AdditionalServiceRepository.UpdateAdditionalServiceAsync(updateDto);
            }
            else
            {
                var addDto = new AddAdditionalServiceDTO
                {
                    TraineeId = selectedTraineeId,
                    ServiceType = serviceName,
                    Price = price,
                    DurationInMinutes = null
                };
                await UnitOfWork.AdditionalServiceRepository.AddAdditionalServiceAsync(addDto);
            }

            await UnitOfWork.CompleteAsync();
            isModalOpen = false;
            await LoadData();
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ExportReport()
    {
        try
        {
            isLoading = true;
            var filePath = await ReportService.ExportAdditionalServicesReportAsync(selectedMonth, selectedYear);
            if (System.IO.File.Exists(filePath))
            {
                var bytes = await System.IO.File.ReadAllBytesAsync(filePath);
                var base64 = Convert.ToBase64String(bytes);
                var fileName = Path.GetFileName(filePath);
                await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, base64);
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"خطأ في التصدير: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteService(int id)
    {
        bool confirmed = await ConfirmService.ShowConfirmAsync($"هل أنت متأكد من الحذف؟");
        if (confirmed)
        {
            await UnitOfWork.AdditionalServiceRepository.DeleteAdditionalServiceAsync(id);
            await UnitOfWork.CompleteAsync();
            await LoadData();
        }
    }
}