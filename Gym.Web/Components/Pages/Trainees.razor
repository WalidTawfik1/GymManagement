@page "/trainees"
@using Gym.Core.Models
@using Gym.Core.DTO
@using Gym.Core.Interfaces
@inject IUnitofWork UnitOfWork
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment
@inject Gym.Core.Interfaces.Services.IReportService ReportService
@rendermode InteractiveServer

<PageTitle>إدارة المتدربين</PageTitle>

<div class="container mx-auto" dir="rtl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div>
            <h2 class="font-bold text-2xl text-gym-primary mb-1">🏃‍♂️ إدارة المتدربين</h2>
            <p class="text-gray-500 text-sm">إدارة معلومات أعضاء النادي والمتدربين</p>
        </div>
        <div class="flex gap-2">
            <button class="btn-outline flex items-center gap-2" @onclick="ExportReport">
                <i class="bi bi-file-earmark-excel"></i> تصدير إكسيل
            </button>
            <button class="btn-primary flex items-center gap-2" @onclick="ShowAddModal">
                <i class="bi bi-plus-lg"></i> إضافة متدرب
            </button>
        </div>
    </div>

    <!-- Search Bar -->
    <div class="flex flex-wrap gap-4 mb-6">
        <div class="w-full md:w-1/2">
            <div class="relative">
                <input type="text" class="input-modern w-full pr-10" placeholder="ابحث باسم المتدرب..." @bind="SearchQuery" @bind:event="oninput" @onkeyup="SearchTrainees" />
                <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                    <i class="bi bi-search text-gray-400"></i>
                </div>
            </div>
        </div>
        <div class="w-full md:w-1/4">
            <select class="input-modern" @bind="SortOrder" @bind:after="SearchTrainees">
                <option value="Newest">الأحدث أولاً</option>
                <option value="Oldest">الأقدم أولاً</option>
            </select>
        </div>
    </div>

    <!-- Table -->
    <div class="card-modern overflow-hidden">
        <div class="overflow-x-auto">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th class="pr-6">الرقم</th>
                        <th>الاسم الكامل</th>
                        <th>رقم الهاتف</th>
                        <th>تاريخ الانضمام</th>
                        <th>الصورة</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-8">
                                <div class="inline-block animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-gym-primary"></div>
                            </td>
                        </tr>
                    }
                    else if (!filteredTrainees.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-8 text-gray-500">لا يوجد متدربين.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var trainee in filteredTrainees)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="pr-6 text-gray-500">#@trainee.Id</td>
                                <td class="font-bold text-gray-800">@trainee.FullName</td>
                                <td class="text-gray-600">@trainee.PhoneNumber</td>
                                <td class="text-gray-600">@trainee.JoinDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(trainee.IdCardPhotoPath))
                                    {
                                        <a href="@trainee.IdCardPhotoPath" target="_blank" class="badge-modern bg-gym-success text-white hover:bg-green-600">عرض الصورة</a>
                                    }
                                    else
                                    {
                                        <span class="badge-modern bg-gray-200 text-gray-600">لا يوجد</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="flex justify-center gap-2">
                                        <button class="btn-outline text-sm" @onclick="() => EditTrainee(trainee)">تعديل</button>
                                        <button class="btn-danger text-sm" @onclick="() => DeleteTrainee(trainee)">حذف</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal for Add/Edit -->
@if (isModalOpen)
{
    <div class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden flex flex-col" dir="rtl">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                <h5 class="font-bold text-lg text-gym-primary">@(isEditMode ? "تعديل المتدرب" : "إضافة متدرب جديد")</h5>
                <button type="button" class="text-gray-400 hover:text-gray-700 text-2xl leading-none" @onclick="CloseModal">&times;</button>
            </div>
            <div class="p-6">
                <div class="mb-4">
                    <label class="block text-sm font-bold text-gray-700 mb-2">الاسم الكامل <span class="text-red-500">*</span></label>
                    <input type="text" class="input-modern" @bind="currentTrainee.FullName" />
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-bold text-gray-700 mb-2">رقم الهاتف <span class="text-red-500">*</span></label>
                    <input type="text" class="input-modern" @bind="currentTrainee.PhoneNumber" />
                </div>
                
                @if(isEditMode)
                {
                    <div class="mb-4">
                        <label class="block text-sm font-bold text-gray-700 mb-2">تاريخ الانضمام</label>
                        <input type="date" class="input-modern" @bind="currentTraineeJoinDate" />
                    </div>
                }

                <div class="mb-4">
                    <label class="block text-sm font-bold text-gray-700 mb-2">صورة البطاقة (اختياري)</label>
                    <InputFile OnChange="HandleFileSelected" class="input-modern bg-white file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-gym-primary hover:file:bg-purple-100" accept="image/*" />
                    @if (!string.IsNullOrEmpty(currentTrainee.IdCardPhotoPath))
                    {
                        <div class="mt-2 text-sm text-gym-success">
                            <i class="bi bi-check-circle"></i> تم إرفاق صورة مسجلة سابقاً
                        </div>
                    }
                </div>
            </div>
            <div class="px-6 py-4 border-t border-gray-100 bg-gray-50 flex justify-end gap-3">
                <button type="button" class="px-5 py-2 rounded-xl font-bold text-gray-600 hover:bg-gray-200 transition-colors" @onclick="CloseModal">إلغاء</button>
                <button type="button" class="btn-primary px-8" @onclick="SaveTrainee">حفظ</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Trainee> trainees = new();
    private List<Trainee> filteredTrainees = new();
    private bool isLoading = true;
    private string SearchQuery = "";
    private string SortOrder = "Newest";
    
    // Modal State
    private bool isModalOpen = false;
    private bool isEditMode = false;
    private Trainee currentTrainee = new();
    private DateTime currentTraineeJoinDate = DateTime.Today;

    private Microsoft.AspNetCore.Components.Forms.IBrowserFile? selectedFile;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        trainees = (await UnitOfWork.TraineeRepository.GetAllTraineesAsync()).ToList();
        SearchTrainees();
        isLoading = false;
    }

    private void SearchTrainees()
    {
        var query = trainees.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(SearchQuery))
        {
            query = query.Where(t => t.FullName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || 
                                     t.PhoneNumber.Contains(SearchQuery));
        }

        if (SortOrder == "Newest")
        {
            filteredTrainees = query.OrderByDescending(t => t.Id).ToList();
        }
        else
        {
            filteredTrainees = query.OrderBy(t => t.Id).ToList();
        }
    }

    private void ShowAddModal()
    {
        isEditMode = false;
        currentTrainee = new Trainee();
        currentTraineeJoinDate = DateTime.Today;
        selectedFile = null;
        isModalOpen = true;
    }

    private void EditTrainee(Trainee trainee)
    {
        isEditMode = true;
        currentTrainee = trainee;
        currentTraineeJoinDate = trainee.JoinDate.ToDateTime(TimeOnly.MinValue);
        selectedFile = null;
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        selectedFile = null;
    }
    
    private void HandleFileSelected(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task SaveTrainee()
    {
        if (string.IsNullOrWhiteSpace(currentTrainee.FullName) || string.IsNullOrWhiteSpace(currentTrainee.PhoneNumber))
        {
            await JS.InvokeVoidAsync("alert", "يرجى تعبئة جميع الحقول المطلوبة.");
            return;
        }
        
        string? imagePath = currentTrainee.IdCardPhotoPath;
        if (selectedFile != null)
        {
            try
            {
                var uploadsDir = Path.Combine(WebHostEnvironment.WebRootPath, "uploads");
                if (!Directory.Exists(uploadsDir))
                {
                    Directory.CreateDirectory(uploadsDir);
                }
                
                var ext = Path.GetExtension(selectedFile.Name);
                var newFileName = $"{Guid.NewGuid()}{ext}";
                var filePath = Path.Combine(uploadsDir, newFileName);
                
                using (var stream = new FileStream(filePath, FileMode.Create))
                {
                    await selectedFile.OpenReadStream(10485760).CopyToAsync(stream); // max 10MB
                }
                
                imagePath = $"/uploads/{newFileName}";
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"حدث خطأ أثناء حفظ الصورة: {ex.Message}");
                return;
            }
        }

        if (isEditMode)
        {
            var updateDto = new UpdateTraineeDTO
            {
                Id = currentTrainee.Id,
                FullName = currentTrainee.FullName,
                PhoneNumber = currentTrainee.PhoneNumber,
                JoinDate = DateOnly.FromDateTime(currentTraineeJoinDate),
                IdCardPhotoPath = imagePath
            };
            await UnitOfWork.TraineeRepository.UpdateTraineeAsync(updateDto);
        }
        else
        {
            var addDto = new TraineeDTO
            {
                FullName = currentTrainee.FullName,
                PhoneNumber = currentTrainee.PhoneNumber,
                IdCardPhotoPath = imagePath
            };
            await UnitOfWork.TraineeRepository.AddTraineeAsync(addDto);
        }

        isModalOpen = false;
        await LoadData();
    }
    
    private async Task ExportReport()
    {
        try
        {
            isLoading = true;
            var filePath = await ReportService.ExportTraineesReportAsync();
            if (System.IO.File.Exists(filePath))
            {
                var bytes = await System.IO.File.ReadAllBytesAsync(filePath);
                var base64 = Convert.ToBase64String(bytes);
                var fileName = Path.GetFileName(filePath);
                await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, base64);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"خطأ في التصدير: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteTrainee(Trainee trainee)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"هل أنت متأكد من حذف المتدرب {trainee.FullName}؟");
        if (confirmed)
        {
            trainee.IsDeleted = true;
            await UnitOfWork.TraineeRepository.UpdateAsync(trainee);
            await LoadData();
        }
    }
}
